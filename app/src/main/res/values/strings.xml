    <string name="background_protection_intro_title">Keep the service alive in the background</string>
    <string name="background_protection_intro_body_xiaomi">Your Xiaomi device is more aggressive about killing background apps. Allow A11Y Button to ignore battery optimization, then lock the app from the recent apps switcher so the shortcut keeps working reliably.</string>
